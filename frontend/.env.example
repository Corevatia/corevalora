### Frontend configuration ###
# Optional: you only need this if the backend isn't at the default
# http://localhost:8000. Otherwise skip it. To override, copy this file to
# frontend/.env and set the value below.
# Note: Vite only exposes variables prefixed with VITE_, and bakes them in at build time.

# Base URL of the backend API. Local dev default is http://localhost:8000
VITE_API_URL=http://localhost:8000
