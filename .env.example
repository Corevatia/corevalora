# --- CoreValora configuration ---
# Copy this file to .env in the project root and fill in the values.
# This single file is read by both docker-compose and the backend.

### Required ###
# API key for MarketStack (stock prices and search)
MARKETSTACK_API_KEY=
# API key for CoinCap (crypto prices)
COINCAP_API_KEY=

# Postgres credentials. The password is the only DB secret you set here;
# the backend builds the connection URL from these parts (see core/config.py),
# and docker-compose uses them for the database container.
POSTGRES_USER=corevalora
POSTGRES_PASSWORD=
POSTGRES_DB=corevalora
# In Docker, POSTGRES_HOST is overridden to "db" by docker-compose.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

### Optional / with defaults ###

# Also log upstream response bodies (debugging only, keep off in prod)
UPSTREAM_DEBUG=false
# Returns mock data instead of calling external APIs
MOCK_DATA=false
# Log Level: DEBUG | INFO | WARNING | ERROR. Use INFO in prod.
LOGGING_LEVEL=INFO

# Send the session cookie over HTTPS only. Local (HTTP): false, prod: true
COOKIE_SECURE=false
# Allowed frontend origins (comma-separated, no wildcard because of cookies)
CORS_ORIGINS=http://localhost:5173
# Logins session lifetime in days
SESSION_LIFETIME_DAYS=1

# Cache lifetimes
CRYPTO_CACHE_TTL_SECONDS=120
STOCK_CACHE_TTL_HOURS=30
SEARCH_CACHE_TTL_HOURS=336
# Interval of the cleanup loop (expired sessions/searches) in hours
MAINTENANCE_LOOP_HOURS=3
